# 配置文件示例
# 使用说明：将此文件复制为 config.yaml，并填写实际的配置值
# 注意：config.yaml 已在 .gitignore 中，不会被提交到 Git

server:
  port: 8567
  context_path: /api

database:
  host: localhost
  port: 3306
  name: ai_passage_creator
  user: root
  password: "your-password"  # 请填写实际密码
  max_idle_conns: 10
  max_open_conns: 100

redis:
  host: localhost
  port: 6379
  db: 0
  password: ""  # Redis 密码，如无则留空

session:
  secret: "your-session-secret-change-this"  # 请生成随机密钥
  max_age: 2592000  # 30天（秒）

# 阿里云 DashScope 配置
ai:
  dashscope:
    api_key: "your-dashscope-api-key"  # https://bailian.console.aliyun.com/
    model: "qwen-max"

# Pexels 图片 API 配置
pexels:
  api_key: "your-pexels-api-key"  # https://www.pexels.com/api/

log:
  level: info  # debug, info, warn, error
  file_path: logs/app.log
